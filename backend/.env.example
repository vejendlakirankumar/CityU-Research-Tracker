APP_NAME="Research Review Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rrp_local
DB_USERNAME=rrp_app
DB_PASSWORD=
DB_SSLMODE=prefer

# ── Cache / Queue / Session ───────────────────────────────────────────────────
BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie
SESSION_LIFETIME=480

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── File Storage ─────────────────────────────────────────────────────────────
# local | azure | s3
FILESYSTEM_DISK=local

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8080,127.0.0.1
SESSION_DOMAIN=localhost

# ── Reverb (WebSocket) ───────────────────────────────────────────────────────
REVERB_APP_ID=rrp-app
REVERB_APP_KEY=rrp-local-key
REVERB_APP_SECRET=rrp-local-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Azure Blob (if FILESYSTEM_DISK=azure) ────────────────────────────────────
# AZURE_STORAGE_NAME=
# AZURE_STORAGE_KEY=
# AZURE_STORAGE_CONTAINER=rrp-uploads

# ── AWS S3 (if FILESYSTEM_DISK=s3) ───────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=rrp-uploads
