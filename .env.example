# ── Site URL (no trailing slash) ────────────────────────────────────
# Dev (local Docker):       http://localhost:8080
# Server / VM (port 80):    http://depoyvm.cityu.edu
WP_URL=http://localhost:8080

# Port to expose on the host (use 80 when running directly on a server)
WP_PORT=8080

# ── WordPress admin account ─────────────────────────────────────────
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=Admin1234!
WP_ADMIN_EMAIL=admin@cityu-test.local

# ── Database ────────────────────────────────────────────────────────
DB_PASSWORD=wp_test_pass
DB_ROOT_PASSWORD=rootpass
